{
    "name": "maize-tech/laravel-mjml",
    "description": "Responsive MJML emails for Laravel",
    "keywords": [
        "Maize",
        "laravel",
        "laravel-mjml"
    ],
    "homepage": "https://github.com/maize-tech/laravel-mjml",
    "license": "MIT",
    "authors": [
        {
            "name": "Riccardo Dalla Via",
            "email": "riccardo.dallavia@maize.io",
            "role": "Developer"
        },
        {
            "name": "Enrico De Lazzari",
            "email": "enrico.delazzari@maize.io",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "spatie/laravel-package-tools": "^1.16.6",
        "spatie/mjml-php": "^1.2"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.8",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.5||^10.0||^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Maize\\Mjml\\": "src/",
            "Maize\\Mjml\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maize\\Mjml\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-laravel-mjml --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maize\\Mjml\\MjmlServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
